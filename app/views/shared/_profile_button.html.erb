<%
  if current_user
    link_path = profile_edit_url
    link_method = :get
    button_text = current_user.name
  else
    link_path = "/auth/discord"
    link_method = :post
    button_text = "Login with Discord"
  end
%>

<%= form_tag link_path, method: link_method, data: { turbo: false }, class: "inline" do %>
  <% if link_method == :get %>
    <%= link_to link_path, data: { turbo: false }, class: "group flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-600/20 hover:bg-primary-600/30 border border-primary-500/50 hover:border-primary-400 text-white transition-all duration-150" do %>
      <span class="text-sm font-medium"><%= button_text %></span>
      <% if current_user&.avatar_url %>
        <div class="rounded-full overflow-hidden ring-2 ring-primary-400/50 group-hover:ring-primary-300/70 transition-all h-7 w-7">
          <%= image_tag current_user.avatar_url, class: "object-cover object-center" %>
        </div>
      <% else %>
        <div class="rounded-full bg-primary-500/30 p-1 group-hover:bg-primary-500/50 transition-colors">
          <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" aria-hidden="true" role="presentation" focusable="false" style="display: block; fill: currentcolor;">
            <path d="m16 .7c-8.437 0-15.3 6.863-15.3 15.3s6.863 15.3 15.3 15.3 15.3-6.863 15.3-15.3-6.863-15.3-15.3-15.3zm0 28c-4.021 0-7.605-1.884-9.933-4.81a12.425 12.425 0 0 1 6.451-4.4 6.507 6.507 0 0 1 -3.018-5.49c0-3.584 2.916-6.5 6.5-6.5s6.5 2.916 6.5 6.5a6.513 6.513 0 0 1 -3.019 5.491 12.42 12.42 0 0 1 6.452 4.4c-2.328 2.925-5.912 4.809-9.933 4.809z"></path>
          </svg>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <%= button_tag type: 'submit', data: { turbo: false }, class: "group flex items-center gap-2 px-4 py-2 rounded-full bg-primary-600/20 hover:bg-primary-600/30 border border-primary-500/50 hover:border-primary-400 text-white transition-all duration-150 cursor-pointer" do %>
      <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true" role="presentation" focusable="false" style="display: block; fill: currentcolor;">
        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"></path>
      </svg>
      <span class="text-sm font-medium"><%= button_text %></span>
    <% end %>
  <% end %>
<% end %>
