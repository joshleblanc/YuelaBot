<%
  # Default button classes
  button_classes = local_assigns[:class] || "inline-flex items-center justify-center px-5 py-2.5 border border-transparent shadow-lg text-sm font-medium rounded-xl text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-all duration-150"
  
  # Extract any data attributes or other HTML options
  html_options = local_assigns.except(:class)
  html_options[:class] = button_classes
  html_options[:type] ||= 'submit'
%>
<%= button_tag html_options do %>
  <%= yield %>
<% end %>
