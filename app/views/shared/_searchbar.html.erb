<%= form_with url: request.path, method: :get, local: true do |form| %>
  <div class="flex items-center gap-3 m-4">
    <div class="relative flex-1">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <%= form.text_field :q, value: params[:q], autofocus: true, placeholder: "Search...", 
          class: "disabled:opacity-50 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 block w-full pl-10 pr-3 py-2.5 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 sm:text-sm transition-all" %>
    </div>
    <div>
      <%= form.submit t("searchbar_component.search"), 
          class: "inline-flex items-center justify-center px-5 py-2.5 border border-transparent shadow-lg text-sm font-medium rounded-xl text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-all" %>
    </div>
  </div>
<% end %>
