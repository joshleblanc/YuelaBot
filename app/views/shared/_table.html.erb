<div class="overflow-x-auto -mx-4 sm:mx-0 rounded-lg">
  <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 w-full">
    <% if local_assigns[:headers] %>
      <thead class="bg-gray-100 dark:bg-gray-800/80">
        <tr>
          <% headers.each do |header| %>
            <th scope="col" class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">
            <%= header %>
          </th>
        <% end %>
      </tr>
    </thead>
  <% end %>
  <tbody class="bg-gray-50 dark:bg-gray-900/50 divide-y divide-gray-200 dark:divide-gray-700">
    <%= yield %>
  </tbody>
</table>
</div>
