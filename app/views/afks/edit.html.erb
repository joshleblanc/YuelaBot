<div class="container mx-auto py-8">
  <div class="max-w-lg mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Editing Afk</h1>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <%= render 'form', afk: @afk %>
    </div>
    <div class="mt-4 space-x-4">
      <%= link_to 'Show', @afk, class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-200" %>
      <%= link_to 'Back', afks_path, class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-200" %>
    </div>
  </div>
</div>
