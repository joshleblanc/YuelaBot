<% content_for(:subnav) do %>
  <%= render 'shared/crayta_sub_nav' %>
<% end %>

<%= render 'shared/searchbar' %>

<div class="flex gap-6 px-4 mb-6">
  <div class="bg-gray-100 dark:bg-gray-800/50 backdrop-blur-sm rounded-xl px-5 py-3 border border-gray-200 dark:border-gray-700/50">
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide"><%= t(".total_visits") %></span>
    <span class="block text-2xl font-bold text-gray-800 dark:text-white"><%= number_to_human CraytaGame.sum(:visits) %></span>
  </div>
  <div class="bg-gray-100 dark:bg-gray-800/50 backdrop-blur-sm rounded-xl px-5 py-3 border border-gray-200 dark:border-gray-700/50">
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide"><%= t(".total_games") %></span>
    <span class="block text-2xl font-bold text-gray-800 dark:text-white"><%= number_to_human CraytaGame.count %></span>
  </div>
</div>

<%= render "crayta/games/table", pagy: @pagy, games: @games %>