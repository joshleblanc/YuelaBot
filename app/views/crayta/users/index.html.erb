<% content_for(:subnav) { render 'shared/crayta_sub_nav' } %>

<%= render 'shared/searchbar' %>

<%= render 'shared/table', headers: [t(".name"), t(".games"), t(".visits"), ''] do %>
  <% @users.each do |user| %>
    <tr class="hover:bg-gray-100 dark:hover:bg-gray-800/70 transition-colors">
      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-200"><%= user.name %></td>
      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400"><%= user.crayta_games.size.to_s %></td>
      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400"><%= user.crayta_games.sum(:visits).to_s %></td>
      <td class="px-6 py-4 whitespace-nowrap text-sm"><%= link_to t(".show"), crayta_user_games_url(user), class: "text-primary-600 dark:text-primary-400 hover:underline" %></td>
    </tr>
  <% end %>
<% end %>
<div class="px-4">
  <%== pagy_nav(@pagy) %>
</div>
<p id="notice" class="text-primary-600 dark:text-primary-400"><%= notice %></p>
